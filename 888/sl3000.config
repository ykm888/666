# 目标平台
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_mt7981_sl3000_spi_rescue=y

# 只生成 initramfs 镜像（不生成 sysupgrade）
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=n
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_IMAGES=y

# SPI‑NOR 驱动
CONFIG_PACKAGE_kmod-spi-mtk-v2=y
CONFIG_PACKAGE_kmod-spi-dev=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_MTD_SPI_NOR=y
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_CMDLINE_PARTS=y

# 基础网络（以太网）
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_kmod-mt7531=y
CONFIG_PACKAGE_kmod-mt7981-eth=y

# 基础网络工具
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iputils-ping=y
CONFIG_PACKAGE_dropbear=y

# 块设备和 eMMC 支持（救砖时挂载 eMMC 刷写固件）
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-mtk=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_e2fsprogs=y

# 救砖工具
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_uboot-envtools-mtk=y
CONFIG_PACKAGE_mtd-utils=y

# 编译选项
CONFIG_DEVEL=y
CONFIG_AUTOREBUILD=y
CONFIG_BUILD_LOG=y

# 内核分区选项
CONFIG_MTD_SPLIT_FIRMWARE=y
CONFIG_MTD_CMDLINE_PARTS=y
CONFIG_MTD_OF_PARTS=y
CONFIG_MTD_BLOCK=y
CONFIG_MTD_BLOCK_RO=y
