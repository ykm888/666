# =================================================================
# 1. 目标平台锁定（SPI-NOR 救砖专用）
# =================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_mt7981_sl3000_spi_rescue=y

# =================================================================
# 2. 内存配置（1GB DDR4）
# =================================================================
CONFIG_TARGET_RAM_SIZE_1024=y
CONFIG_LOW_MEMORY_FOOTPRINT=n
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_PRINTK=y

# =================================================================
# 3. 关闭所有固件镜像构建（核心）
# =================================================================
CONFIG_TARGET_IMAGES=n
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=n
CONFIG_TARGET_ROOTFS_EXT4FS=n

# =================================================================
# 4. 内核体积优化（适配 32MB SPI-NOR）
# =================================================================
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -march=armv8-a+crypto+crc"
CONFIG_KERNEL_GZIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KMOD_SYMTAB=n
CONFIG_CLEAN_IPKG=y

# =================================================================
# 5. 关闭所有 WiFi / LuCI / USB / rootfs 依赖（救砖不需要）
# =================================================================
# CONFIG_PACKAGE_kmod-mt7981-firmware is not set
# CONFIG_PACKAGE_kmod-mt798x-phy-mt7976 is not set
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_luci is not set
# CONFIG_PACKAGE_luci-base is not set
# CONFIG_PACKAGE_luci-app-mtwifi is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set

# =================================================================
# 6. 救砖全家桶核心工具（只保留必要项）
# =================================================================
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_mtd-utils-flashcp=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_hexdump=y
CONFIG_PACKAGE_fdisk=y

# =================================================================
# 7. 基础 BusyBox（initramfs 必需）
# =================================================================
CONFIG_PACKAGE_busybox=y
CONFIG_BUSYBOX_DEFAULT_HEXDUMP=y
CONFIG_BUSYBOX_DEFAULT_DD=y
CONFIG_BUSYBOX_DEFAULT_MOUNT=y
CONFIG_BUSYBOX_DEFAULT_UMOUNT=y
CONFIG_BUSYBOX_DEFAULT_CAT=y
CONFIG_BUSYBOX_DEFAULT_CP=y
CONFIG_BUSYBOX_DEFAULT_LS=y
CONFIG_BUSYBOX_DEFAULT_SH=y
