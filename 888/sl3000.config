# =================================================================
# 1. 目标平台锁定（SPI-NOR 救砖专用）- 修正设备名
# =================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_sl_3000-spi-nor=y   # 改为正确的设备名

# =================================================================
# 2. 内存配置（1GB DDR4）- 删除无效选项
# =================================================================
# CONFIG_TARGET_RAM_SIZE_1024 is not set   # 通常不存在，由 DTS 决定
CONFIG_LOW_MEMORY_FOOTPRINT=n
CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_PRINTK=y

# =================================================================
# 3. 固件镜像构建（启用 squashfs）
# =================================================================
# CONFIG_TARGET_IMAGES is not set   # 删除此行，默认生成镜像
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_ROOTFS_INITRAMFS=n   # 不需要 initramfs

# =================================================================
# 4. 内核体积优化（适配 32MB SPI-NOR）
# =================================================================
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -march=armv8-a+crypto+crc"
CONFIG_KERNEL_GZIP=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KMOD_SYMTAB=n
CONFIG_CLEAN_IPKG=y

# =================================================================
# 5. 关闭 WiFi / LuCI / USB / rootfs 依赖（救砖不需要）
# =================================================================
# CONFIG_PACKAGE_kmod-mt7981-firmware is not set   # 注释掉，需要启用
# CONFIG_PACKAGE_kmod-mt798x-phy-mt7976 is not set
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_luci is not set
# CONFIG_PACKAGE_luci-base is not set
# CONFIG_PACKAGE_luci-app-mtwifi is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set

# =================================================================
# 6. 救砖全家桶核心工具
# =================================================================
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_mtd-utils=y
CONFIG_PACKAGE_mtd-utils-flashcp=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_uboot-envtools-mtk=y
CONFIG_PACKAGE_hexdump=y
CONFIG_PACKAGE_fdisk=y

# 块设备和 eMMC 支持（救砖时挂载 eMMC 需要）
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_kmod-mmc-mtk=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_e2fsprogs=y

# =================================================================
# 7. 基础 BusyBox（保留必要工具）
# =================================================================
CONFIG_PACKAGE_busybox=y
CONFIG_BUSYBOX_DEFAULT_HEXDUMP=y
CONFIG_BUSYBOX_DEFAULT_DD=y
CONFIG_BUSYBOX_DEFAULT_MOUNT=y
CONFIG_BUSYBOX_DEFAULT_UMOUNT=y
CONFIG_BUSYBOX_DEFAULT_CAT=y
CONFIG_BUSYBOX_DEFAULT_CP=y
CONFIG_BUSYBOX_DEFAULT_LS=y
CONFIG_BUSYBOX_DEFAULT_SH=y

# =================================================================
# 8. SPI-NOR 驱动
# =================================================================
CONFIG_PACKAGE_kmod-spi-mtk-v2=y
CONFIG_PACKAGE_kmod-spi-dev=y

# =================================================================
# 9. 以太网 / 交换机驱动（必须）
# =================================================================
CONFIG_PACKAGE_kmod-mt7981-firmware=y   # 必须启用
CONFIG_PACKAGE_kmod-mt7981-eth=y
CONFIG_PACKAGE_kmod-mt7531=y
# CONFIG_PACKAGE_kmod-phy-aquantia is not set
# CONFIG_PACKAGE_kmod-phy-realtek is not set

# =================================================================
# 10. 基础网络栈（最小可用）
# =================================================================
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-reject=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipv6=n
CONFIG_PACKAGE_kmod-nf-flow=y

CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_dnsmasq-mini=y
CONFIG_PACKAGE_dropbear=y
